    "#| echo: true\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "# Example data\n",
    "data = np.array([\n",
    "    [23, 45, 12, 34, 56],\n",
    "    [33, 54, 22, 43, 66],\n",
    "    [12, 34, 15, 28, 39],\n",
    "    [44, 55, 31, 47, 62]\n",
    "])\n",
    "\n",
    "# Axis labels\n",
    "days = ['Monday', 'Tuesday', 'Wednesday', 'Thursday']\n",
    "hours = ['9–11', '11–13', '13–15', '15–17', '17–19']\n",
    "\n",
    "# Creating the heatmap\n",
    "plt.figure(figsize=(8, 6))\n",
    "cax = plt.imshow(data, cmap='Greens')\n",
    "\n",
    "# Axis labels\n",
    "plt.xticks(ticks=np.arange(len(hours)), labels=hours, rotation=45, ha='right')\n",
    "plt.yticks(ticks=np.arange(len(days)), labels=days)\n",
    "\n",
    "# Adding numeric values\n",
    "for i in range(data.shape[0]):\n",
    "    for j in range(data.shape[1]):\n",
    "        plt.text(j, i, str(data[i, j]), ha='center', va='center', color='black')\n",
    "\n",
    "# Colorbar\n",
    "plt.colorbar(cax, orientation='vertical', label='Number of customers')\n",
    "\n",
    "# Title and layout\n",
    "plt.title('Number of customers in the store by day and hour')\n",
    "plt.tight_layout()\n",
    "\n",
    "# Displaying the chart\n",
